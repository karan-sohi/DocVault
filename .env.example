# ── Database ──────────────────────────────────────────────
DATABASE_URL=postgresql://docvault:docvault@localhost:5432/docvault

# ── Storage ───────────────────────────────────────────────
# Options: local | s3
STORAGE_DRIVER=local
LOCAL_UPLOAD_DIR=./uploads

# S3 (only needed when STORAGE_DRIVER=s3)
AWS_S3_BUCKET=your-bucket-name
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# ── Email (SMTP) ───────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=karansinghsohi7@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM="DocVault <noreply@docvault.io>"

# ── App ───────────────────────────────────────────────────
APP_BASE_URL=http://localhost:5173
PORT=3000

# Cron: how often to check for notifications (default: every hour)
NOTIFICATION_CHECK_CRON=0 * * * *
